PORT=8080

DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.PROJECT_REF
DB_PASSWORD=SUPABASE_DB_PASSWORD
DB_DRIVER=org.postgresql.Driver
DB_MAX_POOL_SIZE=2
DB_MIN_IDLE=0
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=300000
DB_MAX_LIFETIME=1800000
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false

JAVA_TOOL_OPTIONS=-Xms64m -Xmx512m -Xss512k -XX:MaxMetaspaceSize=192m -XX:ReservedCodeCacheSize=64m -XX:MaxDirectMemorySize=64m -XX:+UseSerialGC -XX:ActiveProcessorCount=1 -XX:TieredStopAtLevel=1 -XX:+ExitOnOutOfMemoryError
SERVER_TOMCAT_THREADS_MAX=20
SERVER_TOMCAT_THREADS_MIN_SPARE=2
SERVER_TOMCAT_MAX_CONNECTIONS=100
SERVER_TOMCAT_ACCEPT_COUNT=20
SERVER_TOMCAT_PROCESSOR_CACHE=10

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

ORDER_SHIPPING_FEE=0

PAYMENT_QR_BANK_ID=970454
PAYMENT_QR_ACCOUNT=
PAYMENT_QR_ACQ_NAME=
PAYMENT_QR_TEMPLATE=compact2

MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=10MB
APP_STORAGE_UPLOAD_ROOT=./data/uploads

STORE_CONTACT_NAME=Gia Thinh Shop
STORE_CONTACT_PHONE=0900000000
STORE_CONTACT_ZALO=0900000000
STORE_CONTACT_ADDRESS=927 Nguyễn Ảnh Thủ, Trung Mỹ Tây, TPHCM
